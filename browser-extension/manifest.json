{
  "manifest_version": 3,
  "name": "MyWhoosh to Garmin Uploader",
  "version": "0.2.48",
  "description": "Upload MyWhoosh FIT activities to Garmin Connect using your current Chrome session.",
  "icons": {
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "notifications",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.mywhoosh.com/*",
    "https://connect.garmin.com/*",
    "https://connectapi.garmin.com/*",
    "https://sso.garmin.com/*",
    "https://thegarth.s3.amazonaws.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "MyWhoosh -> Garmin",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://event.mywhoosh.com/*",
        "https://*.mywhoosh.com/*"
      ],
      "js": [
        "content-mywhoosh.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
